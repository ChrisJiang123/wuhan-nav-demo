# ===== map-bff =====
# 自建 OSRM 路由引擎地址
OSRM_BASE_URL=http://localhost:5000
# 自建矢量瓦片服务地址
TILESERVER_BASE_URL=http://localhost:8080
# POI 搜索后端（自建 nominatim 或预处理 POI 服务）
SEARCH_BASE_URL=http://localhost:7070
BFF_PORT=3000

# ===== report-service =====
REPORT_PORT=3001
DATABASE_URL=postgresql://user:pass@localhost:5432/wuhan_nav
REDIS_URL=redis://localhost:6379

# ===== 通用 =====
# 环境：dev / demo
APP_ENV=dev
# 上报图片存储（本地目录或对象存储），demo 用本地即可
UPLOAD_DIR=./uploads

# 注意：本项目不使用任何商业地图厂商 key（高德/百度/Google 均不需要）
# 注意：禁止把真实 .env 提交进 git
