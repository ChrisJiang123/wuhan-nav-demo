{
  "name": "wuhan-nav-demo",
  "version": "0.1.0",
  "private": true,
  "description": "Android-only Wuhan navigation demo built with OpenStreetMap, MapLibre, and a self-hosted routing stack.",
  "workspaces": [
    "apps/*",
    "services/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint:packages && npm run lint:backend && npm run lint:flutter",
    "lint:packages": "bash scripts/ci/package-lint.sh",
    "lint:backend": "bash scripts/ci/backend-lint.sh",
    "lint:flutter": "bash scripts/ci/flutter-analyze.sh",
    "test": "npm run test --workspaces --if-present"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=20"
  }
}
